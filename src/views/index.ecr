<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Visual Compiler Trace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/styles/github.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/codemirror@5.65.16/lib/codemirror.min.css">
  <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/highlight.min.js"></script>
  <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/languages/crystal.min.js"></script>
  <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/languages/llvm.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/codemirror@5.65.16/lib/codemirror.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/codemirror@5.65.16/mode/crystal/crystal.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/codemirror@5.65.16/addon/mode/simple.min.js"></script>
  <style>
    :root {
      color-scheme: light;
      --bg: #f5f6f8;
      --panel: #ffffff;
      --line: #d9dde5;
      --ink: #23262d;
      --sub: #5f6675;
      --accent: #2f67ff;
      --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
      --sans: system-ui, -apple-system, "Segoe UI", sans-serif;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 16px;
      background: var(--bg);
      color: var(--ink);
      font-family: var(--sans);
      min-height: 100vh;
    }

    h1 {
      margin: 0 0 12px;
      font-size: 20px;
    }

    .layout {
      display: grid;
      grid-template-columns: 1fr 10px 1fr 10px 1fr;
      gap: 0;
      height: calc(100vh - 56px);
    }

    .pane {
      border: 1px solid var(--line);
      background: var(--panel);
      border-radius: 8px;
      display: flex;
      flex-direction: column;
      min-width: 0;
      min-height: 0;
    }

    .gutter {
      position: relative;
      cursor: col-resize;
      user-select: none;
    }

    .gutter::before {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 2px;
      transform: translateX(-50%);
      background: var(--line);
      border-radius: 999px;
    }

    body.resizing,
    body.resizing * {
      user-select: none;
      cursor: col-resize !important;
    }

    .pane-header {
      padding: 10px 12px;
      border-bottom: 1px solid var(--line);
      font-size: 13px;
      color: var(--sub);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
    }

    .pane-content {
      padding: 10px 12px;
      overflow: auto;
      min-height: 0;
      flex: 1;
    }

    .source-editor {
      width: 100%;
      height: calc(100% - 96px);
      border: 1px solid var(--line);
      border-radius: 6px;
      overflow: hidden;
      background: #fcfdff;
    }

    .CodeMirror {
      height: 100%;
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.5;
    }

    .llvm-editor {
      width: 100%;
      height: 100%;
      border: 1px solid var(--line);
      border-radius: 6px;
      overflow: hidden;
      background: #fcfdff;
    }

    button {
      border: none;
      background: var(--accent);
      color: #fff;
      border-radius: 6px;
      padding: 8px 12px;
      font-weight: 600;
      cursor: pointer;
      font-size: 12px;
    }

    .status {
      font-size: 12px;
      color: var(--sub);
    }

    .status.running {
      color: var(--accent);
      font-weight: 600;
    }

    .status.error {
      color: #8e2b2b;
      font-weight: 600;
    }

    .progress {
      margin-top: 8px;
      padding: 8px 10px;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: #f7f9ff;
      display: none;
      align-items: center;
      gap: 10px;
      font-size: 12px;
      color: var(--sub);
    }

    .progress.visible {
      display: flex;
    }

    .spinner {
      width: 14px;
      height: 14px;
      border: 2px solid #c5d3ff;
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      flex: 0 0 auto;
    }

    .progress-meta {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      min-width: 0;
    }

    .phase {
      color: var(--ink);
      font-weight: 600;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .tabs {
      display: flex;
      gap: 6px;
      overflow-x: auto;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 8px;
    }

    .tab {
      border: 1px solid var(--line);
      background: #f2f5fc;
      color: var(--ink);
      border-radius: 999px;
      padding: 4px 10px;
      font-size: 12px;
      cursor: pointer;
      white-space: nowrap;
    }

    .tab.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    .meta {
      font-size: 12px;
      color: var(--sub);
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6px 12px;
      margin-bottom: 8px;
    }

    .mono {
      font-family: var(--mono);
      font-size: 12px;
      line-height: 1.45;
      margin: 0;
      overflow: auto;
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 8px;
      background: #fcfdff;
    }

    .mono code {
      display: block;
      white-space: pre;
      font-family: inherit;
      background: transparent !important;
      padding: 0;
    }

    .section-title {
      font-size: 12px;
      color: var(--sub);
      margin: 8px 0 4px;
    }

    .diff-plus { color: #0f6f2f; }
    .diff-minus { color: #8e2b2b; }
  </style>
</head>
<body>
  <h1>Visual Compiler Trace (Local)</h1>
  <div class="layout" id="layout">
    <section class="pane">
      <div class="pane-header">
        <span>Input (Crystal)</span>
        <span id="status" class="status">ready</span>
      </div>
      <div class="pane-content">
        <div id="sourceEditor" class="source-editor"></div>
        <div style="display:flex; gap:8px; margin-top:8px; align-items:center;">
          <button id="runBtn" type="button">Trace</button>
          <label class="status" for="preludeSel">prelude</label>
          <select id="preludeSel">
            <option value="nano" selected>nano</option>
            <option value="prelude">prelude</option>
            <option value="empty">empty</option>
          </select>
          <span class="status">canonical parse → semantic summary → codegen</span>
        </div>
        <div id="progress" class="progress" aria-live="polite">
          <span class="spinner" aria-hidden="true"></span>
          <div class="progress-meta">
            <span id="phaseText" class="phase">準備中</span>
            <span id="elapsedText">0.0s</span>
          </div>
        </div>
      </div>
    </section>

    <div class="gutter" data-gutter="0"></div>

    <section class="pane">
      <div class="pane-header">
        <span>Stage Snapshots</span>
        <span id="stageSummary" class="status">-</span>
      </div>
      <div class="pane-content">
        <div id="tabs" class="tabs"></div>
        <div class="section-title">Stage Diff</div>
        <pre id="diff" class="mono"></pre>
        <div id="meta" class="meta"></div>
        <div class="section-title">Semantic Summary</div>
        <pre id="semanticSummary" class="mono"></pre>
        <div class="section-title">Program Metadata</div>
        <pre id="programMeta" class="mono"></pre>
        <div class="section-title">Compile Log</div>
        <pre id="compileLog" class="mono"></pre>
        <div class="section-title">AST Tree</div>
        <pre id="tree" class="mono"></pre>
        <div class="section-title">AST Text</div>
        <pre class="mono"><code id="astText" class="language-crystal"></code></pre>
      </div>
    </section>

    <div class="gutter" data-gutter="1"></div>

    <section class="pane">
      <div class="pane-header">
        <span>LLVM IR</span>
        <span class="status" id="llvmMeta">-</span>
      </div>
      <div class="pane-content">
        <div id="llvmEditor" class="llvm-editor"></div>
      </div>
    </section>
  </div>

  <script>
    const sourceEditorHost = document.getElementById("sourceEditor");
    const layoutEl = document.getElementById("layout");
    const runBtn = document.getElementById("runBtn");
    const preludeSel = document.getElementById("preludeSel");
    const statusEl = document.getElementById("status");
    const tabsEl = document.getElementById("tabs");
    const metaEl = document.getElementById("meta");
    const treeEl = document.getElementById("tree");
    const astTextEl = document.getElementById("astText");
    const diffEl = document.getElementById("diff");
    const semanticSummaryEl = document.getElementById("semanticSummary");
    const programMetaEl = document.getElementById("programMeta");
    const compileLogEl = document.getElementById("compileLog");
    const llvmEditorHost = document.getElementById("llvmEditor");
    const stageSummaryEl = document.getElementById("stageSummary");
    const llvmMetaEl = document.getElementById("llvmMeta");
    const progressEl = document.getElementById("progress");
    const phaseTextEl = document.getElementById("phaseText");
    const elapsedTextEl = document.getElementById("elapsedText");

    let snapshots = [];
    let programMetadata = null;
    let semanticSummary = null;
    let compileLog = "";
    let activeIndex = 0;
    let progressTimer = null;
    const sourceEditor = CodeMirror(sourceEditorHost, {
      value: `# nano prelude default sample
# (use prelude=prelude when you want stdlib helpers like puts)

1 + 2
`,
      mode: "crystal",
      lineNumbers: true,
      tabSize: 2,
      indentUnit: 2,
      indentWithTabs: false,
      lineWrapping: false,
    });

    CodeMirror.defineSimpleMode("llvm-lite", {
      start: [
        {regex: /;.*$/, token: "comment"},
        {regex: /\bdefine\b|\bdeclare\b|\bret\b|\bbr\b|\bswitch\b|\binvoke\b|\bcall\b|\bphi\b|\balloca\b|\bload\b|\bstore\b|\bgetelementptr\b|\bbitcast\b|\btrunc\b|\bzext\b|\bsext\b|\bfptrunc\b|\bfpext\b|\bptrtoint\b|\binttoptr\b|\bextractvalue\b|\binsertvalue\b|\bunreachable\b|\bselect\b|\bicmp\b|\bfcmp\b|\badd\b|\bsub\b|\bmul\b|\budiv\b|\bsdiv\b|\bfadd\b|\bfsub\b|\bfmul\b|\bfdiv\b|\band\b|\bor\b|\bxor\b|\bshl\b|\blshr\b|\bashr\b|\bmodule\b|\btarget\b|\bdatalayout\b|\battributes\b/, token: "keyword"},
        {regex: /\bvoid\b|\bi1\b|\bi8\b|\bi16\b|\bi32\b|\bi64\b|\bi128\b|\bfloat\b|\bdouble\b|\blabel\b|\bptr\b/, token: "atom"},
        {regex: /@[A-Za-z_.$][\w.$]*/, token: "def"},
        {regex: /%[A-Za-z_.$][\w.$]*/, token: "variable-2"},
        {regex: /"(?:[^\\"]|\\.)*"/, token: "string"},
        {regex: /[-+]?\d+(?:\.\d+)?(?:e[-+]?\d+)?/, token: "number"},
        {regex: /[{}()\[\],]/, token: "bracket"},
      ],
      meta: {
        lineComment: ";",
      },
    });

    const llvmEditor = CodeMirror(llvmEditorHost, {
      value: "",
      mode: "llvm-lite",
      lineNumbers: true,
      readOnly: true,
      lineWrapping: false,
    });

    function setupPaneResizer() {
      const panes = Array.from(layoutEl.querySelectorAll(".pane"));
      const gutters = Array.from(layoutEl.querySelectorAll(".gutter"));
      if (panes.length !== 3 || gutters.length !== 2) return;

      const minPaneWidth = 220;
      const gutterWidth = 10;
      const weights = [1, 1, 1];

      function applyColumns() {
        layoutEl.style.gridTemplateColumns = `${weights[0]}fr ${gutterWidth}px ${weights[1]}fr ${gutterWidth}px ${weights[2]}fr`;
      }

      function startDrag(gutterIndex, startX) {
        const leftIndex = gutterIndex;
        const rightIndex = gutterIndex + 1;
        const leftRect = panes[leftIndex].getBoundingClientRect();
        const rightRect = panes[rightIndex].getBoundingClientRect();
        const pairWidth = leftRect.width + rightRect.width;
        const totalWeight = weights[0] + weights[1] + weights[2];
        const ratioScale = totalWeight / Math.max(layoutEl.clientWidth - gutterWidth * gutters.length, 1);

        function onMove(event) {
          const delta = event.clientX - startX;
          let nextLeft = leftRect.width + delta;
          nextLeft = Math.max(minPaneWidth, Math.min(pairWidth - minPaneWidth, nextLeft));
          const nextRight = pairWidth - nextLeft;

          weights[leftIndex] = nextLeft * ratioScale;
          weights[rightIndex] = nextRight * ratioScale;
          applyColumns();
        }

        function onUp() {
          document.body.classList.remove("resizing");
          window.removeEventListener("pointermove", onMove);
          window.removeEventListener("pointerup", onUp);
        }

        document.body.classList.add("resizing");
        window.addEventListener("pointermove", onMove);
        window.addEventListener("pointerup", onUp);
      }

      gutters.forEach((gutter, index) => {
        gutter.addEventListener("pointerdown", (event) => {
          event.preventDefault();
          startDrag(index, event.clientX);
        });
      });

      applyColumns();
    }

    function setStatus(text) {
      statusEl.textContent = text;
    }

    function renderHighlighted(codeEl, text, language) {
      codeEl.textContent = text || "";
      codeEl.className = `language-${language}`;
      if (window.hljs) hljs.highlightElement(codeEl);
    }

    function setStatusRunning(isRunning) {
      statusEl.classList.toggle("running", isRunning);
    }

    function setStatusError(isError) {
      statusEl.classList.toggle("error", isError);
    }

    function phaseByElapsed(seconds) {
      if (seconds < 3.0) return "Canonical Parse";
      if (seconds < 10.0) return "Semantic Summary";
      return "Generate LLVM IR";
    }

    function renderSummaryBlock(summary) {
      if (!summary) return "(semantic summary unavailable)";
      return Object.entries(summary)
        .map(([key, value]) => `${key}: ${value}`)
        .join("\n");
    }

    function renderCompileLog(text) {
      if (!text || text.trim() === "") return "(no compile log)";
      const lines = text.split("\n");
      const tail = lines.slice(Math.max(lines.length - 40, 0));
      return tail.join("\n");
    }

    function startProgress() {
      progressEl.classList.add("visible");
      const started = performance.now();
      const update = () => {
        const elapsed = (performance.now() - started) / 1000;
        phaseTextEl.textContent = phaseByElapsed(elapsed);
        elapsedTextEl.textContent = `${elapsed.toFixed(1)}s`;
      };
      update();
      progressTimer = setInterval(update, 100);
    }

    function stopProgress() {
      if (progressTimer) {
        clearInterval(progressTimer);
        progressTimer = null;
      }
      progressEl.classList.remove("visible");
    }

    function renderTabs() {
      tabsEl.innerHTML = "";
      snapshots.forEach((snapshot, index) => {
        const button = document.createElement("button");
        button.className = "tab" + (index === activeIndex ? " active" : "");
        button.textContent = `${snapshot.label}`;
        button.onclick = () => {
          activeIndex = index;
          renderTabs();
          renderSnapshot();
        };
        tabsEl.appendChild(button);
      });
    }

    function renderSnapshot() {
      const snapshot = snapshots[activeIndex];
      if (!snapshot) {
        metaEl.innerHTML = "";
        treeEl.textContent = "";
        renderHighlighted(astTextEl, "", "crystal");
        diffEl.textContent = "";
        semanticSummaryEl.textContent = "";
        programMetaEl.textContent = "";
        compileLogEl.textContent = "";
        stageSummaryEl.textContent = "-";
        return;
      }

      const metaRows = [
        ["stage", snapshot.label],
        ["elapsed", `${snapshot.elapsed_ms} ms`],
        ["node_count", `${snapshot.node_count}`],
      ];

      const extra = snapshot.metadata || {};
      Object.keys(extra).forEach((key) => {
        if (!["stage", "summary"].includes(key)) {
          metaRows.push([key, String(extra[key])]);
        }
      });

      metaEl.innerHTML = metaRows
        .map(([k, v]) => `<div><strong>${k}</strong>: ${v}</div>`)
        .join("");

      treeEl.textContent = (snapshot.tree || []).join("\n");
      renderHighlighted(astTextEl, snapshot.ast_text || "", "crystal");

      const diffLines = snapshot.diff || [];
      if (diffLines.length === 0) {
        diffEl.textContent = "(no diff)";
      } else {
        diffEl.innerHTML = diffLines
          .map((line) => {
            if (line.startsWith("+")) return `<span class=\"diff-plus\">${line}</span>`;
            if (line.startsWith("-")) return `<span class=\"diff-minus\">${line}</span>`;
            return line;
          })
          .join("\n");
      }

      const summary = extra.summary ? ` / ${extra.summary}` : "";
      stageSummaryEl.textContent = `${snapshot.label}${summary}`;
      semanticSummaryEl.textContent = renderSummaryBlock(semanticSummary);
      compileLogEl.textContent = renderCompileLog(compileLog);

      if (!programMetadata) {
        programMetaEl.textContent = "(compiler metadata unavailable)";
      } else {
        const counts = [
          ["types", programMetadata.types_count],
          ["symbols", programMetadata.symbols_count],
          ["unions", programMetadata.unions_count],
          ["vars", programMetadata.vars_count],
          ["const_initializers", programMetadata.const_initializers_count],
          ["class_var_initializers", programMetadata.class_var_initializers_count],
          ["file_modules", programMetadata.file_modules_count],
          ["requires", programMetadata.requires_count],
        ].map(([k, v]) => `${k}: ${v}`).join("\n");

        const sampleTypes = (programMetadata.sample_types || []).slice(0, 20).join(", ");
        const sampleSymbols = (programMetadata.sample_symbols || []).slice(0, 20).join(", ");
        const sampleRequires = (programMetadata.sample_requires || []).slice(0, 20).join("\n");

        programMetaEl.textContent =
          `${counts}\n\n` +
          `sample_types:\n${sampleTypes || "(none)"}\n\n` +
          `sample_symbols:\n${sampleSymbols || "(none)"}\n\n` +
          `sample_requires:\n${sampleRequires || "(none)"}`;
      }
    }

    async function trace() {
      setStatus("running...");
      setStatusRunning(true);
      setStatusError(false);
      runBtn.disabled = true;
      startProgress();

      try {
        const prelude = preludeSel.value || "nano";
        const response2 = await fetch(`/api/trace?prelude=${encodeURIComponent(prelude)}`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ code: sourceEditor.getValue() }),
        });

        const data = await response2.json();
        if (!response2.ok || data.errors) {
          const message = data.errors?.[0]?.message || "unknown error";
          throw new Error(message);
        }

        snapshots = data.snapshots || [];
        programMetadata = data.program_metadata || null;
        semanticSummary = data.semantic_summary || null;
        compileLog = data.compile_log || "";
        activeIndex = 0;
        renderTabs();
        renderSnapshot();

        llvmEditor.setValue(data.llvm_ir || "");
        llvmEditor.refresh();
        const llvmLines = (data.llvm_ir || "").split("\n").length;
        llvmMetaEl.textContent = `${llvmLines} lines`;

        setStatus(`ok (${data.prelude || prelude})`);
        setStatusRunning(false);
      } catch (error) {
        snapshots = [];
        programMetadata = null;
        semanticSummary = null;
        compileLog = "";
        renderTabs();
        renderSnapshot();
        llvmEditor.setValue("");
        llvmEditor.refresh();
        llvmMetaEl.textContent = "-";
        setStatus(`error: ${error.message}`);
        setStatusRunning(false);
        setStatusError(true);
      } finally {
        stopProgress();
        runBtn.disabled = false;
      }
    }

    runBtn.addEventListener("click", trace);
    setupPaneResizer();
    sourceEditor.refresh();
    trace();
  </script>
</body>
</html>
